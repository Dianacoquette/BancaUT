@model BancaUT.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BancaUT - Iniciar sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page-body">
    <div class="auth-shell">
        <div class="auth-brand-panel">
            <span class="badge rounded-pill text-bg-light text-primary mb-3">BancaUT</span>
            <h1 class="display-6 fw-bold mb-3">Administra tu dinero con el mismo estilo de tu dashboard.</h1>
            <p class="lead text-white-50 mb-4">Registra ingresos, controla egresos, evita gastar de más y mantén tus metas y presupuestos siempre visibles.</p>
            <div class="auth-feature-list">
                <div><i class="bi bi-check2-circle"></i> Balance general y reportes mensuales</div>
                <div><i class="bi bi-check2-circle"></i> Alertas de presupuesto y recordatorios</div>
                <div><i class="bi bi-check2-circle"></i> Historial completo de movimientos</div>
            </div>
        </div>

        <div class="auth-card auth-card-clean">
            <div class="text-center mb-4">
                <div class="auth-logo-circle mb-3"><i class="bi bi-shield-lock"></i></div>
                <h2 class="fw-bold mb-1">Iniciar sesión</h2>
                <p class="text-muted mb-0">Ingresa para entrar a tu panel financiero.</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group auth-input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group auth-input-group">
                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Tu contraseña" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <a asp-action="ForgotPassword" class="auth-link">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg auth-submit">Entrar al dashboard</button>
            </form>

            <div class="text-center mt-4 text-muted">
                ¿No tienes cuenta? <a asp-action="Register" class="auth-link fw-semibold">Crear cuenta</a>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
