<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BancaUT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }
    <nav class="navbar navbar-expand-lg navbar-dark navbar-banca">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-bank me-2"></i>BancaUT
            </a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Movimientos" ? "active" : "")"
                           asp-controller="Movimientos" asp-action="Index">
                            <i class="bi bi-clock-history"></i> Historial
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Categorias" ? "active" : "")"
                           asp-controller="Categorias" asp-action="Index">
                            <i class="bi bi-tags"></i> Categorías
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Presupuestos" ? "active" : "")"
                           asp-controller="Presupuestos" asp-action="Index">
                            <i class="bi bi-wallet2"></i> Presupuestos
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Metas" ? "active" : "")"
                           asp-controller="Metas" asp-action="Index">
                            <i class="bi bi-piggy-bank"></i> Metas
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Recordatorios" ? "active" : "")"
                           asp-controller="Recordatorios" asp-action="Index">
                            <i class="bi bi-bell"></i> Recordatorios
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentController == "Reportes" ? "active" : "")"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-graph-up-arrow"></i> Reportes
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Reportes" asp-action="BalanceGeneral">Balance general</a></li>
                            <li><a class="dropdown-item" asp-controller="Reportes" asp-action="Mensual">Reporte mensual</a></li>
                        </ul>
                    </li>
                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="text-center py-4 text-muted small">
        © 2026 BancaUT - Control financiero personal
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
