@model IEnumerable<BancaUT.Models.ViewModels.PresupuestoIndexViewModel>
@{
    ViewData["Title"] = "Presupuestos";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h2 class="fw-bold mb-1">Presupuestos</h2>
        <p class="text-muted mb-0">Crea presupuestos mensuales por categoría y recibe alertas cuando estés por excederlos.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nuevo presupuesto</a>
</div>

<div class="card card-soft">
    <div class="card-body p-4">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Categoría</th>
                            <th>Límite mensual</th>
                            <th>Mes</th>
                            <th>Año</th>
                            <th>Gastado</th>
                            <th>Alerta de presupuesto</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Categoria</td>
                            <td>$@item.MontoLimite.ToString("N2")</td>
                            <td>@item.Mes</td>
                            <td>@item.Anio</td>
                            <td>$@item.Gastado.ToString("N2")</td>
                            <td style="min-width: 230px;">
                                <div class="progress mb-1">
                                    <div class="progress-bar @(item.Excedido ? "bg-danger" : item.PorcentajeUsado >= 80 ? "bg-warning" : "bg-success")" style="width:@Math.Min(item.PorcentajeUsado,100)%"></div>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <span>@item.PorcentajeUsado.ToString("N1")%</span>
                                    <span class="@(item.Excedido ? "text-danger" : "text-muted")">
                                        @(item.Excedido ? "Excedido" : $"Disponible: ${item.Disponible:N2}")
                                    </span>
                                </div>
                            </td>
                            <td class="text-end">
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Deseas eliminar este presupuesto?');">Eliminar</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">Aún no tienes presupuestos creados.</p>
        }
    </div>
</div>
