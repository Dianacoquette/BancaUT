@model BancaUT.Models.Presupuesto
@{
    ViewData["Title"] = "Crear presupuesto";
}

<div class="card card-soft form-soft">
    <div class="card-body p-4">
        <h2 class="fw-bold mb-3">Crear presupuesto</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label">Categoría de gasto</label>
                <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias">
                    <option value="">Selecciona una categoría</option>
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MontoLimite" class="form-label">Límite mensual</label>
                <input asp-for="MontoLimite" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="MontoLimite" class="text-danger"></span>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Mes" class="form-label"></label>
                    <input asp-for="Mes" class="form-control" type="number" min="1" max="12" />
                    <span asp-validation-for="Mes" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Anio" class="form-label">Año</label>
                    <input asp-for="Anio" class="form-control" type="number" min="2000" max="2100" />
                    <span asp-validation-for="Anio" class="text-danger"></span>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
