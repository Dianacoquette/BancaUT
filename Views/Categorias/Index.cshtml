@model IEnumerable<BancaUT.Models.Categoria>
@{
    ViewData["Title"] = "Categorías";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h2 class="fw-bold mb-1">Categorías</h2>
        <p class="text-muted mb-0">Crea, edita y elimina categorías para ingresos y gastos.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nueva categoría</a>
</div>

<div class="card card-soft">
    <div class="card-body p-4">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td><span class="badge @(item.Tipo == "Ingreso" ? "text-bg-success" : "text-bg-danger")">@item.Tipo</span></td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Deseas eliminar esta categoría?');">Eliminar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">Aún no tienes categorías registradas.</p>
        }
    </div>
</div>
