@model BancaUT.Models.MetaAhorro
@{
    ViewData["Title"] = "Crear meta de ahorro";
}

<div class="card card-soft form-soft">
    <div class="card-body p-4">
        <h2 class="fw-bold mb-3">Crear meta de ahorro</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej. Vacaciones, laptop, fondo de emergencia" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="MontoObjetivo" class="form-label"></label>
                    <input asp-for="MontoObjetivo" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="MontoObjetivo" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MontoActual" class="form-label">Monto inicial</label>
                    <input asp-for="MontoActual" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="MontoActual" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaInicio" class="form-label">Fecha de inicio</label>
                    <input asp-for="FechaInicio" class="form-control" type="date" value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="FechaInicio" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaObjetivo" class="form-label">Fecha objetivo</label>
                    <input asp-for="FechaObjetivo" class="form-control" type="date" value="@Model.FechaObjetivo.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="FechaObjetivo" class="text-danger"></span>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
